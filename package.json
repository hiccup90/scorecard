{
  "name": "scorecard",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "dev": "go run ./cmd/scorecard",
    "build:web": "npm --prefix web run build",
    "build:api": "go build -o dist/scorecard ./cmd/scorecard",
    "build": "npm run build:web && npm run build:api",
    "test": "go test ./... -count=1",
    "check": "go test ./... -count=1 && npm --prefix web run build",
    "lint": "go vet ./..."
  }
}
